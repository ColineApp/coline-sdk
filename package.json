{
  "name": "@colineapp/sdk",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p ./tsconfig.build.json",
    "generate:openapi": "node ./scripts/generate-openapi.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "openapi-fetch": "^0.17.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.8.2",
    "vitest": "^4.0.18"
  }
}
